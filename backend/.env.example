APP_NAME=Interactive AI Scene Explorer
APP_ENV=development
STATIC_URL_PREFIX=/static
REPOSITORY_BACKEND=memory
SQLITE_PATH=backend/dev.sqlite3
ASYNC_JOBS_ENABLED=true
CLEANUP_GENERATED_ASSETS_ON_NEW_STORY=true

# mock | diffusion
IMAGE_GENERATOR_BACKEND=mock

# sd15 | sdxl
DIFFUSION_MODEL_FAMILY=sd15
DIFFUSION_CHECKPOINT_PATH=model/Base_model/dreamshaper_8.safetensors
DIFFUSION_LORA_PATH=model/Lora/Edward_Hopper-000001.safetensors
DIFFUSION_LORA_SCALE=0.8
DIFFUSION_OUTPUT_WIDTH=768
DIFFUSION_OUTPUT_HEIGHT=432
DIFFUSION_STEPS=24
DIFFUSION_GUIDANCE_SCALE=7.0
DIFFUSION_IMG2IMG_STRENGTH=0.62
DIFFUSION_FOCUS_CROP_PADDING=1.6
DIFFUSION_CPU_OFFLOAD=false
DIFFUSION_NEGATIVE_PROMPT=text, watermark, logo, blurry, low quality, distorted, duplicate objects, cropped
